generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Listing {
  id        String   @id @db.VarChar(64)
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id        String   @id @db.VarChar(64)
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
