<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Agen | Rumah123</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { brand: { DEFAULT: '#E02020', dark: '#C41E1E', light: '#FFF5F5' } },
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
                },
            },
        };
    </script>
    <style>body { font-family: 'Inter', system-ui, sans-serif; }</style>
    <script src="/agent/auth.js"></script>
</head>
<body class="bg-slate-900 min-h-screen flex flex-col text-slate-800 antialiased">
    <div class="flex-1 flex items-center justify-center px-4 py-12">
        <div class="w-full max-w-md">
            <div class="text-center mb-8">
                <a href="/" class="inline-flex items-center gap-1 text-white/90 hover:text-white text-sm mb-6">
                    <span aria-hidden="true">←</span> Kembali ke situs publik
                </a>
                <div class="flex justify-center items-baseline gap-1 mb-2">
                    <span class="text-3xl font-bold text-brand">Rumah</span>
                    <span class="text-3xl font-bold text-white">123</span>
                </div>
                <p class="text-slate-400 text-sm">Area agen</p>
                <h1 id="login-heading" class="text-xl font-bold text-white mt-4">Masuk sebagai agen</h1>
            </div>

            <div class="bg-white rounded-2xl shadow-xl border border-slate-200/10 p-6 sm:p-8">
                <div id="logged-in-panel" class="hidden space-y-5 text-center">
                    <p class="text-slate-600 text-sm leading-relaxed">
                        Anda sudah masuk sebagai<br>
                        <strong id="logged-email" class="text-slate-900 text-base"></strong>
                    </p>
                    <a href="/agent/dashboard" id="btn-to-dashboard" class="inline-flex w-full justify-center items-center bg-brand hover:bg-brand-dark text-white font-bold py-3 rounded-xl shadow-md transition focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2">
                        Ke dashboard
                    </a>
                    <button type="button" id="btn-logout-from-login" class="w-full text-slate-600 hover:text-slate-900 text-sm font-medium py-2 rounded-lg border border-slate-200 hover:bg-slate-50 transition">
                        Keluar
                    </button>
                </div>

                <form id="form-login" class="space-y-5" novalidate>
                    <div>
                        <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email agen</label>
                        <input type="email" id="email" name="email" required autocomplete="username" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-brand/30 focus:border-brand outline-none" placeholder="agen@email.com">
                    </div>
                    <div>
                        <label for="password" class="block text-sm font-medium text-slate-700 mb-1">Kata sandi</label>
                        <input type="password" id="password" name="password" required autocomplete="current-password" minlength="6" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-brand/30 focus:border-brand outline-none" placeholder="••••••••">
                    </div>
                    <p id="err-msg" class="hidden text-sm text-red-600 bg-red-50 border border-red-100 rounded-lg px-3 py-2"></p>
                    <button type="submit" id="btn-submit" class="w-full bg-brand hover:bg-brand-dark text-white font-bold py-3 rounded-xl shadow-md transition focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2">
                        Masuk
                    </button>
                </form>
                <p id="login-hint" class="text-xs text-slate-400 mt-6 text-center leading-relaxed">
                    Gunakan email agen yang ada di database. Sandi default setelah impor: <code class="bg-slate-100 px-1 rounded">demo12345</code> (bisa diubah lewat <code class="bg-slate-100 px-1 rounded">AGENT_DEFAULT_PASSWORD</code> di <code class="bg-slate-100 px-1 rounded">.env</code>).
                </p>
            </div>
        </div>
    </div>

    <script>
(function () {
    (async function initSessionUi() {
        if (typeof AgentAuth === 'undefined') return;
        await AgentAuth.refresh();
        if (!AgentAuth.isLoggedIn()) return;
        var panel = document.getElementById('logged-in-panel');
        var form = document.getElementById('form-login');
        var hint = document.getElementById('login-hint');
        if (panel) panel.classList.remove('hidden');
        if (form) form.classList.add('hidden');
        if (hint) hint.classList.add('hidden');
        var emailEl = document.getElementById('logged-email');
        if (emailEl) emailEl.textContent = AgentAuth.getEmail() || '';
        var h = document.getElementById('login-heading');
        if (h) h.textContent = 'Selamat datang kembali';
    })();

    document.getElementById('btn-logout-from-login').addEventListener('click', async function () {
        await AgentAuth.logout();
        window.location.reload();
    });

    document.getElementById('form-login').addEventListener('submit', async function (e) {
        e.preventDefault();
        var email = (document.getElementById('email').value || '').trim();
        var password = document.getElementById('password').value || '';
        var err = document.getElementById('err-msg');
        err.classList.add('hidden');

        if (!email || !password) {
            err.textContent = 'Isi email dan kata sandi.';
            err.classList.remove('hidden');
            return;
        }

        var ok = await AgentAuth.login(email, password);
        if (!ok) {
            err.textContent = 'Email atau kata sandi tidak sesuai.';
            err.classList.remove('hidden');
            return;
        }
        window.location.href = '/agent/dashboard';
    });
})();
    </script>
</body>
</html>
