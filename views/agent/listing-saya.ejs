<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Listing saya | Rumah123 Agen</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { brand: { DEFAULT: '#E02020', dark: '#C41E1E', light: '#FFF5F5' } },
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
                },
            },
        };
    </script>
    <style>body { font-family: 'Inter', system-ui, sans-serif; }</style>
    <script src="/agent/auth.js"></script>
</head>
<body class="bg-[#f0f2f5] text-slate-800 min-h-screen antialiased">
    <script>
        (async function () {
            if (typeof AgentAuth === 'undefined') { window.location.href = '/agent/login'; return; }
            var ok = await AgentAuth.guard('/agent/login');
            if (!ok) return;
        })();
    </script>

    <div class="min-h-screen flex">
        <aside class="hidden md:flex w-56 lg:w-64 bg-slate-900 text-slate-300 flex-col shrink-0">
            <div class="p-5 border-b border-slate-700/80">
                <div class="flex items-baseline gap-1">
                    <span class="text-xl font-bold text-brand">Rumah</span>
                    <span class="text-xl font-bold text-white">123</span>
                </div>
                <p class="text-xs text-slate-500 mt-1">Panel agen</p>
            </div>
            <nav class="flex-1 p-3 space-y-1">
                <a href="/agent/dashboard" class="flex items-center gap-2 px-3 py-2.5 rounded-lg hover:bg-white/5 text-sm transition">Dashboard</a>
                <a href="/agent/listing-saya" class="flex items-center gap-2 px-3 py-2.5 rounded-lg bg-white/10 text-white font-medium text-sm">Listing saya</a>
                <a href="/agent/pesan" class="flex items-center gap-2 px-3 py-2.5 rounded-lg hover:bg-white/5 text-sm transition">Pesan</a>
                <a href="/agent/profil" class="flex items-center gap-2 px-3 py-2.5 rounded-lg hover:bg-white/5 text-sm transition">Profil</a>
            </nav>
            <div class="p-3 border-t border-slate-700/80">
                <a href="/" class="block text-xs text-slate-500 hover:text-white px-3 py-2">← Situs publik</a>
                <button type="button" id="btn-logout" class="mt-2 w-full text-left px-3 py-2 text-sm text-red-400 hover:text-red-300 rounded-lg hover:bg-white/5">Keluar</button>
            </div>
        </aside>

        <div class="flex-1 flex flex-col min-w-0">
            <header class="bg-white border-b border-slate-200 px-4 sm:px-6 py-4">
                <div class="flex flex-wrap items-center justify-between gap-3">
                    <div>
                        <h1 class="text-lg sm:text-xl font-bold text-slate-900">Listing saya</h1>
                        <p class="text-sm text-slate-500">Hanya listing milik akun Anda</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <span id="agent-badge" class="hidden sm:inline text-sm text-slate-600 truncate max-w-[200px]"></span>
                        <button type="button" id="btn-logout-mobile" class="md:hidden text-sm font-medium text-brand">Keluar</button>
                    </div>
                </div>
                <nav class="md:hidden mt-4 flex gap-2 overflow-x-auto pb-1 -mx-1 px-1 text-sm">
                    <a href="/agent/dashboard" class="shrink-0 px-3 py-1.5 rounded-lg bg-slate-100 text-slate-700">Dashboard</a>
                    <a href="/agent/listing-saya" class="shrink-0 px-3 py-1.5 rounded-lg bg-brand text-white font-medium">Listing</a>
                    <a href="/agent/pesan" class="shrink-0 px-3 py-1.5 rounded-lg bg-slate-100 text-slate-700">Pesan</a>
                    <a href="/agent/profil" class="shrink-0 px-3 py-1.5 rounded-lg bg-slate-100 text-slate-700">Profil</a>
                </nav>
            </header>

            <main class="flex-1 p-4 sm:p-6 lg:p-8">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
                    <div class="flex flex-wrap gap-2">
                        <button type="button" data-filter="all" class="filter-tab px-4 py-2 rounded-lg text-sm font-medium bg-brand text-white">Semua</button>
                        <button type="button" data-filter="aktif" class="filter-tab px-4 py-2 rounded-lg text-sm font-medium bg-white border border-slate-200 text-slate-700 hover:border-brand/40">Aktif</button>
                        <button type="button" data-filter="tayang" class="filter-tab px-4 py-2 rounded-lg text-sm font-medium bg-white border border-slate-200 text-slate-700 hover:border-brand/40">Tayang</button>
                        <button type="button" data-filter="draft" class="filter-tab px-4 py-2 rounded-lg text-sm font-medium bg-white border border-slate-200 text-slate-700 hover:border-brand/40">Draft</button>
                    </div>
                    <a href="/agent/listing-form" class="inline-flex items-center justify-center gap-2 bg-slate-900 hover:bg-slate-800 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition">
                        + Listing baru
                    </a>
                </div>

                <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="min-w-full text-sm">
                            <thead class="bg-slate-50 text-slate-600 text-left">
                                <tr>
                                    <th class="px-4 py-3 font-semibold">Properti</th>
                                    <th class="px-4 py-3 font-semibold">Harga</th>
                                    <th class="px-4 py-3 font-semibold">Status</th>
                                    <th class="px-4 py-3 font-semibold">Wilayah</th>
                                    <th class="px-4 py-3 font-semibold text-right">Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="listing-body" class="divide-y divide-slate-100"></tbody>
                        </table>
                    </div>
                    <p id="listing-empty" class="hidden px-4 py-10 text-center text-slate-500 text-sm">Belum ada listing.</p>
                </div>
            </main>
        </div>
    </div>

    <script>
(function () {
    var LIST = [];

    function badgeStatus(s) {
        if (s === 'draft') return '<span class="inline-flex px-2 py-0.5 rounded text-xs font-semibold bg-slate-100 text-slate-600">Draft</span>';
        if (s === 'tayang') return '<span class="inline-flex px-2 py-0.5 rounded text-xs font-semibold bg-emerald-50 text-emerald-700">Tayang</span>';
        return '<span class="inline-flex px-2 py-0.5 rounded text-xs font-semibold bg-blue-50 text-blue-700">Aktif</span>';
    }

    function esc(s) {
        var d = document.createElement('div');
        d.textContent = s == null ? '' : String(s);
        return d.innerHTML;
    }

    function formatCompactPrice(p) {
        var juta = Number(p && p.priceJuta);
        if (!isFinite(juta) || juta < 0) return '—';
        var rupiah = juta * 1000000;
        var suffix = p && p.transaction === 'disewa' ? ' / tahun' : '';

        function trim2(n) {
            var v = Math.round(n * 100) / 100;
            return String(v).replace(/\.0+$/, '').replace(/(\.\d*[1-9])0+$/, '$1');
        }

        if (rupiah >= 1e12) return 'Rp ' + trim2(rupiah / 1e12) + ' Triliun' + suffix;
        if (rupiah >= 1e9) return 'Rp ' + trim2(rupiah / 1e9) + ' Miliar' + suffix;
        if (rupiah >= 1e6) return 'Rp ' + trim2(rupiah / 1e6) + ' Juta' + suffix;
        if (rupiah >= 1e3) return 'Rp ' + trim2(rupiah / 1e3) + ' Ribu' + suffix;
        return 'Rp ' + Math.round(rupiah).toLocaleString('id-ID') + suffix;
    }

    function render(filter) {
        var body = document.getElementById('listing-body');
        var empty = document.getElementById('listing-empty');
        body.innerHTML = '';
        var list = LIST.map(function (p) {
            var n = parseInt(p.id, 10);
            var status = p.priceJuta > 0 ? 'tayang' : 'draft';
            var filt = status === 'draft' ? 'draft' : (status === 'tayang' ? 'tayang' : 'aktif');
            var wilayah = [p.regencyName || p.city, p.districtName || p.location].filter(Boolean).join(', ');
            return {
                raw: p,
                title: p.title,
                price: formatCompactPrice(p),
                status: status,
                filter: filt,
                wilayah: wilayah || '—',
            };
        }).filter(function (r) {
            if (filter === 'all') return true;
            return r.filter === filter;
        });
        if (!list.length) {
            empty.classList.remove('hidden');
            return;
        }
        empty.classList.add('hidden');
        list.forEach(function (r) {
            var tr = document.createElement('tr');
            tr.className = 'hover:bg-slate-50/80';
            var detail = '/properti-detail?id=' + encodeURIComponent(r.raw.id);
            tr.innerHTML =
                '<td class="px-4 py-3"><p class="font-medium text-slate-900">' + esc(r.title) + '</p><p class="text-xs text-slate-400 mt-0.5">ID: ' + esc(r.raw.listingCode || r.raw.id) + '</p></td>' +
                '<td class="px-4 py-3 text-slate-800 whitespace-nowrap">' + esc(r.price) + '</td>' +
                '<td class="px-4 py-3">' + badgeStatus(r.status) + '</td>' +
                '<td class="px-4 py-3 text-slate-600">' + esc(r.wilayah) + '</td>' +
                '<td class="px-4 py-3 text-right space-x-2 whitespace-nowrap">' +
                '<a href="' + esc(detail) + '" class="text-brand font-medium hover:underline">Lihat</a>' +
                '<a href="/agent/listing-form?id=' + encodeURIComponent(r.raw.id) + '" class="text-slate-500 hover:text-slate-800">Edit</a>' +
                '</td>';
            body.appendChild(tr);
        });
    }

    async function load() {
        await AgentAuth.refresh();
        if (!AgentAuth.isLoggedIn()) return;
        document.getElementById('agent-badge').textContent = AgentAuth.getEmail();
        var r = await fetch('/api/agent/listings', { credentials: 'same-origin' });
        if (!r.ok) return;
        LIST = await r.json();
        render('all');
    }

    load();

    var current = 'all';
    document.querySelectorAll('.filter-tab').forEach(function (btn) {
        btn.addEventListener('click', function () {
            current = btn.getAttribute('data-filter') || 'all';
            document.querySelectorAll('.filter-tab').forEach(function (b) {
                var on = b.getAttribute('data-filter') === current;
                b.className = 'filter-tab px-4 py-2 rounded-lg text-sm font-medium ' + (on ? 'bg-brand text-white' : 'bg-white border border-slate-200 text-slate-700 hover:border-brand/40');
            });
            render(current);
        });
    });

    async function doLogout() {
        await AgentAuth.logout();
        window.location.href = '/agent/login';
    }
    document.getElementById('btn-logout').addEventListener('click', doLogout);
    document.getElementById('btn-logout-mobile').addEventListener('click', doLogout);
})();
    </script>
</body>
</html>
